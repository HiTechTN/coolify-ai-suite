# Coolify AI Suite - Configuration
# Version: 2.0
# Copiez ce fichier en .env et adaptez selon vos besoins

# ============================================
# PORTS
# ============================================
OLLAMA_PORT=11434
CODE_SERVER_PORT=8443
OPEN_WEBUI_PORT=3000
COOLIFY_PORT=8000

# ============================================
# MOTS DE PASSE (générer avec: openssl rand -base64 24)
# ============================================
CODE_SERVER_PASSWORD=
WEBUI_SECRET=

# ============================================
# BACKUP
# ============================================
BACKUP_DIR=/opt/backups/ai-suite
RETENTION_DAYS=7

# ============================================
# RÉSEAU
# ============================================
NETWORK_NAME=ai-suite
AI_SUITE_DIR=/opt/ai-suite